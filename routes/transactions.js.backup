const express = require('express');
const router = express.Router();
const Transaction = require('../models/Transaction');
const User = require('../models/User');
const Service = require('../models/Service');
const jwt = require('jsonwebtoken');
const upload = require('../middleware/upload');

const auth = (req, res, next) => {
  const token = req.headers.authorization?.split(' ')[1];
  if (!token) return res.status(401).json({ error: 'No token provided' });
  
  try {
    const decoded = jwt.verify(token, process.env.JWT_SECRET || 'your-secret-key');
    req.userId = decoded.userId;
    next();
  } catch (err) {
    res.status(401).json({ error: 'Invalid token' });
  }
};

// Create transaction request with job description images
router.post('/request', auth, upload.array('jobImages', 5), async (req, res) => {
  try {
    const { serviceId, providerId, randAmount, description } = req.body;
    
    // Check if user has enough Rand
    const requester = await User.findById(req.userId);
    if (requester.randBalance < randAmount) {
      return res.status(400).json({ error: 'Insufficient Rand balance' });
    }

    // Move Rand to escrow
    requester.randBalance -= parseFloat(randAmount);
    requester.escrowRand += parseFloat(randAmount);
    await requester.save();

    // Handle job description images
    const jobDescriptionImages = req.files ? req.files.map(file => ({
      url: `/uploads/proof/${file.filename}`,
      caption: req.body.caption || '',
      uploadedAt: new Date()
    })) : [];

    const transaction = new Transaction({
      requesterId: req.userId,
      providerId,
      serviceId,
      randAmount: parseFloat(randAmount),
      jobDescriptionImages,
      status: 'pending',
      escrowStatus: 'held'
    });

    await transaction.save();

    res.json({
      message: 'Service requested. Rand held in escrow.',
      transactionId: transaction._id,
      jobImages: jobDescriptionImages.length
    });
  } catch (err) {
    console.error('Request error:', err);
    res.status(500).json({ error: 'Server error' });
  }
});

// Accept transaction
router.post('/accept/:id', auth, async (req, res) => {
  try {
    const transaction = await Transaction.findOne({
      _id: req.params.id,
      providerId: req.userId,
      status: 'pending'
    });

    if (!transaction) {
      return res.status(404).json({ error: 'Transaction not found' });
    }

    transaction.status = 'accepted';
    await transaction.save();

    res.json({ message: 'Transaction accepted' });
  } catch (err) {
    res.status(500).json({ error: 'Server error' });
  }
});

// Complete transaction with proof images
router.post('/complete/:id', auth, upload.array('proofImages', 5), async (req, res) => {
  try {
    const { rating, review } = req.body;

    const transaction = await Transaction.findOne({
      _id: req.params.id,
      $or: [
        { requesterId: req.userId },
        { providerId: req.userId }
      ],
      status: { $in: ['accepted', 'in_progress'] }
    });

    if (!transaction) {
      return res.status(404).json({ error: 'Transaction not found' });
    }

    // Handle uploaded proof images
    const proofImages = req.files ? req.files.map(file => ({
      url: `/uploads/proof/${file.filename}`,
      uploadedBy: req.userId,
      uploadedAt: new Date(),
      caption: req.body.caption || ''
    })) : [];

    if (proofImages.length > 0) {
      transaction.proofImages = [...(transaction.proofImages || []), ...proofImages];
    }

    // Release escrow to provider
    const requester = await User.findById(transaction.requesterId);
    const provider = await User.findById(transaction.providerId);

    requester.escrowRand -= transaction.randAmount;
    provider.randBalance += transaction.randAmount;
    provider.totalEarnedRand += transaction.randAmount;

    await requester.save();
    await provider.save();

    // Update transaction
    transaction.status = 'completed';
    transaction.escrowStatus = 'released';
    transaction.completedAt = new Date();

    if (transaction.requesterId.toString() === req.userId) {
      transaction.providerRating = rating;
      transaction.providerReview = review;
    } else {
      transaction.requesterRating = rating;
      transaction.requesterReview = review;
    }

    await transaction.save();

    // Update provider stats
    const service = await Service.findById(transaction.serviceId);
    if (service) {
      service.completedJobsCount += 1;
      
      const allTransactions = await Transaction.find({
        providerId: transaction.providerId,
        status: 'completed',
        providerRating: { $exists: true }
      });

      if (allTransactions.length > 0) {
        const avgRating = allTransactions.reduce((sum, t) => sum + (t.providerRating || 5), 0) / allTransactions.length;
        service.averageRating = Math.round(avgRating * 10) / 10;
        provider.rating = service.averageRating;
        await provider.save();
      }

      await service.save();
    }

    res.json({
      message: 'Transaction completed. Rand released to provider.',
      proofImages: transaction.proofImages
    });
  } catch (err) {
    console.error('Complete error:', err);
    res.status(500).json({ error: 'Server error' });
  }
});

// Cancel transaction and refund escrow
router.post('/cancel/:id', auth, async (req, res) => {
  try {
    const transaction = await Transaction.findOne({
      _id: req.params.id,
      $or: [{ requesterId: req.userId }, { providerId: req.userId }],
      status: { $in: ['pending', 'accepted'] }
    });

    if (!transaction) {
      return res.status(404).json({ error: 'Transaction not found or cannot be cancelled' });
    }

    // Refund to requester
    const requester = await User.findById(transaction.requesterId);
    requester.escrowRand -= transaction.randAmount;
    requester.randBalance += transaction.randAmount;
    await requester.save();

    transaction.status = 'cancelled';
    transaction.escrowStatus = 'refunded';
    await transaction.save();

    res.json({ message: 'Transaction cancelled. Rand refunded.' });
  } catch (err) {
    res.status(500).json({ error: 'Server error' });
  }
});

// Get user's transactions
router.get('/my-transactions', auth, async (req, res) => {
  try {
    const transactions = await Transaction.find({
      $or: [{ requesterId: req.userId }, { providerId: req.userId }]
    })
    .populate('serviceId', 'title category')
    .populate('requesterId', 'name')
    .populate('providerId', 'name')
    .sort({ createdAt: -1 });

    res.json(transactions);
  } catch (err) {
    res.status(500).json({ error: 'Server error' });
  }
});

// Get provider's completed jobs (for portfolio)
router.get('/provider/:providerId/completed', async (req, res) => {
  try {
    const transactions = await Transaction.find({
      providerId: req.params.providerId,
      status: 'completed'
    })
    .populate('serviceId', 'title category')
    .populate('requesterId', 'name')
    .sort({ completedAt: -1 });

    res.json(transactions);
  } catch (err) {
    res.status(500).json({ error: 'Server error' });
  }
});

module.exports = router;

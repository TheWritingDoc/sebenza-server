const express = require('express');
const router = express.Router();
const Service = require('../models/Service');
const jwt = require('jsonwebtoken');

// Middleware to verify JWT
const auth = (req, res, next) => {
  const token = req.headers.authorization?.split(' ')[1];
  if (!token) return res.status(401).json({ error: 'No token provided' });
  
  try {
    const decoded = jwt.verify(token, process.env.JWT_SECRET || 'your-secret-key');
    req.userId = decoded.userId;
    next();
  } catch (err) {
    res.status(401).json({ error: 'Invalid token' });
  }
};

// Create service (no images - they come from completed transactions)
router.post('/create', auth, async (req, res) => {
  try {
    const { title, description, category, credits, location } = req.body;
    
    const service = new Service({
      providerId: req.userId,
      title,
      description,
      category,
      credits,
      location,
      completedJobsCount: 0,
      averageRating: 5
    });

    await service.save();
    
    // Populate provider info before returning
    await service.populate('providerId', 'name rating verified');
    
    res.json({ message: 'Service created successfully', service });
  } catch (err) {
    console.error('Create service error:', err);
    res.status(500).json({ error: 'Server error creating service' });
  }
});

// Get provider's services
router.get('/my-services', auth, async (req, res) => {
  try {
    const services = await Service.find({ providerId: req.userId })
      .sort({ createdAt: -1 });
    res.json(services);
  } catch (err) {
    res.status(500).json({ error: 'Server error' });
  }
});

// Delete service
router.delete('/:serviceId', auth, async (req, res) => {
  try {
    const service = await Service.findOneAndDelete({
      _id: req.params.serviceId,
      providerId: req.userId
    });
    
    if (!service) {
      return res.status(404).json({ error: 'Service not found' });
    }
    
    res.json({ message: 'Service deleted' });
  } catch (err) {
    res.status(500).json({ error: 'Server error' });
  }
});

module.exports = router;

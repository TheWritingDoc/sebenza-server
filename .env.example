# ── Sebenza server environment ──
# Copy to .env for local dev. In production these are set in Render → Environment.

NODE_ENV=development
PORT=3001

# Auth — MUST be a strong random string in production (server refuses to boot
# in prod with a weak/default value).
JWT_SECRET=change-me-to-a-long-random-string

# ── Database (Supabase Postgres via Prisma) ──
# Runtime uses the transaction pooler (port 6543) with pgbouncer=true.
# DIRECT_URL (port 5432) is used only by the Prisma CLI for migrations.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ── Supabase Storage (uploads) ──
# Without these, uploads fall back to ephemeral local disk (dev only).
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── CORS ── comma-separated allowed origins (production)
CORS_ORIGINS=https://sebenza-server.onrender.com

# ── SMS (Twilio) ── phone signup/verification. Without these, phone OTP is
# disabled in production (503) and returned in the response only in dev.
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_PHONE=

# ── Email (SMTP) ── email verification. Same demo/prod behaviour as SMS.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=Sebenza <no-reply@sebenza.app>
# Or use SendGrid instead of SMTP:
# SENDGRID_API_KEY=

# ── Cron ── shared secret for the external job-sweep trigger
# (.github/workflows/sweep.yml). Set the same value as a GitHub repo secret.
CRON_SECRET=

# ── Error tracking (Sentry) ── create a free project at sentry.io and paste
# its DSN; error reporting turns on automatically. Empty = disabled.
SENTRY_DSN=
# Log verbosity for structured logs (pino): trace|debug|info|warn|error
LOG_LEVEL=info
